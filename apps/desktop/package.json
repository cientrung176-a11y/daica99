{
  "name": "@dai-ca/desktop",
  "version": "1.0.3",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && cross-env ELECTRON_DEV=1 electron .\"",
    "prebuild": "node scripts/gen-icon.cjs",
    "build": "vite build && electron-builder --win",
    "release": "vite build && electron-builder --win --publish always",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "electron-updater": "^6.3.4",
    "lucide-react": "^0.441.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.2",
    "recharts": "^2.12.7",
    "socket.io-client": "^4.7.5",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/react": "^18.3.8",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "32.3.3",
    "electron-builder": "^25.0.5",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.12",
    "typescript": "^5.5.4",
    "vite": "^5.4.7",
    "wait-on": "^8.0.1"
  },
  "author": {
    "name": "CienNT"
  },
  "build": {
    "appId": "com.daica99bacninh.app",
    "productName": "ĐẠI CA 99 BẮC NINH",
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico",
      "legalTrademarks": "CienNT",
      "signtoolOptions": {
        "publisherName": "CienNT"
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "ĐẠI CA 99 BẮC NINH",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/icon.png"
    ],
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "GITHUB_USERNAME",
      "repo": "dai-ca-99-bacninh",
      "releaseType": "release"
    }
  }
}
